{
  "name": "ironcore",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "docker:db": "docker compose --env-file .env -f docker/docker-compose.yml up -d db",
    "docker:dev:up": "docker compose --env-file .env -f docker/docker-compose.dev.yml up",
    "docker:dev:down": "docker compose --env-file .env -f docker/docker-compose.dev.yml down",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "check-types": "npm run typecheck",
    "db:validate": "npm run db:validate --workspace=apps/api",
    "db:generate": "npm run db:generate --workspace=apps/api",
    "db:migrate": "npm run db:migrate --workspace=apps/api",
    "db:migrate:deploy": "npm run db:migrate:deploy --workspace=apps/api",
    "db:seed": "npm run db:seed --workspace=apps/api",
    "db:studio": "npm run db:studio --workspace=apps/api"
  },
  "devDependencies": {
    "prettier": "^3.6.0",
    "turbo": "^2.9.14"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
